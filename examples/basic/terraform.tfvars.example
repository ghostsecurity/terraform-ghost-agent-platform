# Copy this file to terraform.tfvars and fill in real values.
# terraform.tfvars is gitignored — never commit real values.

# ----------------------------------------------------------------------
# Provided by Ghost Security during onboarding
# ----------------------------------------------------------------------

# Ghost's ECR registry hosting the platform images. Format is
#   <12-digit-account>.dkr.ecr.<region>.amazonaws.com
# Ghost will share this value alongside the cross-account ECR pull
# grant for the AWS account this module is deployed into.
image_registry = "REPLACE_ME.dkr.ecr.us-east-1.amazonaws.com"

# Released image tag to deploy. Ghost publishes signed tags in the
# `vX.Y.Z` semver format. Check with Ghost for the latest released
# version, or pin to a specific one for reproducibility.
image_tag = "vX.Y.Z"

# ----------------------------------------------------------------------
# Local choices
# ----------------------------------------------------------------------

# AWS region for the deployment.
aws_region = "us-east-1"

# CIDR allowed SSH (port 22) access to the VM. Use an office IP /32
# or VPN egress block — avoid 0.0.0.0/0. Find the current public IP
# with:
#   curl -4 https://checkip.amazonaws.com
#
# Note: this only gates the SSH security-group rule. SSM Session
# Manager (the default access path) bypasses this entirely. When
# ssh_key_name is left empty below, no key pair is attached and
# admin_cidr is effectively a defense-in-depth setting only.
admin_cidr = "203.0.113.42/32"

# Email for the initial admin user seeded at first boot. The password
# is auto-generated by Terraform and stored in AWS Secrets Manager —
# the README explains how to retrieve it after `terraform apply`.
seed_admin_email = "you@example.com"

# Optional: an existing EC2 key pair name to enable SSH access. Leave
# this commented out to skip — AWS Systems Manager Session Manager is
# the default access path and works without a key pair (the instance
# role grants SSM access; cloud-init installs the agent). Only set
# this if you want SSH as a real fallback to SSM.
# ssh_key_name = "my-key-pair"
